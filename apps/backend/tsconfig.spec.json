{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "rootDir": "src",
    "outDir": "dist-spec",
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "resolvePackageJsonExports": false
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
