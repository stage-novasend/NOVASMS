# Email providers
EMAIL_PROVIDER=resend
RESEND_API_KEY=
# Default safe sender for staging/dev. Use your verified domain in production.
RESEND_FROM=NovaSMS <onboarding@resend.dev>
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=

# Optional test mode for email redirection
RESEND_TEST_RECIPIENT=

# SMS providers
# twilio = default provider, africastalking = better fit for CI/Africa
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
AFRICASTALKING_SENDER_ID=
# Optional override (auto: sandbox host when username=sandbox)
AFRICASTALKING_BASE_URL=

# Public frontend URL used inside email links
FRONTEND_PUBLIC_URL=http://localhost:5173

# Campaign image storage
# Local dev: point these to MinIO and keep the bucket public
# Staging/prod: point these to your public S3 bucket endpoint
CAMPAIGN_IMAGE_STORAGE_PROVIDER=s3
CAMPAIGN_IMAGE_BUCKET=novasms-campaign-images
CAMPAIGN_IMAGE_PUBLIC_BASE_URL=http://localhost:9000/novasms-campaign-images
CAMPAIGN_IMAGE_S3_REGION=us-east-1
CAMPAIGN_IMAGE_S3_ENDPOINT=http://localhost:9000
CAMPAIGN_IMAGE_S3_ACCESS_KEY_ID=minioadmin
CAMPAIGN_IMAGE_S3_SECRET_ACCESS_KEY=minioadmin
CAMPAIGN_IMAGE_S3_FORCE_PATH_STYLE=true
