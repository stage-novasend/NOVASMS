# =============================================================================
# NovaSMS Backend — .env.example
# Copier vers .env et remplir les valeurs. Ne jamais versionner .env.
# STAGING ET PRODUCTION = EXACTEMENT LE MEME CODE. Seul .env differe.
# =============================================================================

# --- Application --------------------------------------------------------------
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# --- Base de donnees ----------------------------------------------------------
DATABASE_URL=postgresql://novasms:novasms_dev_password_2026@localhost:5432/novasms_db?schema=public

# --- Redis / BullMQ -----------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- JWT ----------------------------------------------------------------------
JWT_ACCESS_SECRET=change_me_min_32_chars
JWT_ACCESS_EXPIRATION=8h
JWT_REFRESH_SECRET=change_me_different_min_32_chars
JWT_REFRESH_EXPIRATION=30d

# =============================================================================
# EMAIL --- EMAIL_PROVIDER=mock | resend | brevo
# Staging  : EMAIL_PROVIDER=mock
# Prod     : EMAIL_PROVIDER=resend  (ou brevo)
# =============================================================================
EMAIL_PROVIDER=mock

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=NovaSMS <onboarding@resend.dev>
RESEND_TEST_RECIPIENT=

BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
BREVO_FROM_EMAIL=no-reply@novasms.io
BREVO_FROM_NAME=NovaSMS

# =============================================================================
# SMS --- SMS_PROVIDER=simulation | novasend | africastalking | twilio
# Staging  : SMS_PROVIDER=simulation   (logs console, aucun envoi reel)
# Prod     : SMS_PROVIDER=novasend     (ou africastalking / twilio)
# =============================================================================
SMS_PROVIDER=simulation

# NovaSend SMS (prod West Africa)
NOVASEND_SMS_API_KEY=ns_sms_xxxxxxxxxxxxxxxxxxxx
NOVASEND_SMS_SENDER_ID=NovaSMS
NOVASEND_SMS_BASE_URL=https://api.novasend.io/v1

# Africa's Talking
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=
AFRICASTALKING_BASE_URL=

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# =============================================================================
# TARIFICATION --- Coût par envoi facturé au client (en FCFA)
# SMS     : parties × contacts × CREDIT_COST_PER_SMS
# Email   : contacts × CREDIT_COST_PER_EMAIL
# WhatsApp: contacts × CREDIT_COST_PER_WHATSAPP
# =============================================================================
CREDIT_COST_PER_SMS=12
CREDIT_COST_PER_EMAIL=2
CREDIT_COST_PER_WHATSAPP=35

# =============================================================================
# MOBILE MONEY --- MOBILE_MONEY_PROVIDER=simulation | novasend
# Staging  : MOBILE_MONEY_PROVIDER=simulation
# Prod     : MOBILE_MONEY_PROVIDER=novasend
# =============================================================================
MOBILE_MONEY_PROVIDER=simulation

# Auth NovaSend : Basic base64(NOVASEND_MM_API_KEY:NOVASEND_MM_API_CLIENT)
NOVASEND_MM_API_KEY=ns_mm_xxxxxxxxxxxxxxxxxxxx
NOVASEND_MM_API_CLIENT=xxxxxxxxxxxxxxxxxxxxxxxx
NOVASEND_MM_BASE_URL=https://business.novasend.app/v1

# =============================================================================
# VISA / CARTE --- VISA_PROVIDER=simulation | stripe
# Staging  : VISA_PROVIDER=simulation   (succes immediat, aucun appel Stripe)
# Test     : VISA_PROVIDER=stripe + STRIPE_SECRET_KEY=sk_test_xxx
# Prod     : VISA_PROVIDER=stripe + STRIPE_SECRET_KEY=sk_live_xxx
# =============================================================================
VISA_PROVIDER=simulation

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# PUSH / WHATSAPP
# =============================================================================
PUSH_PROVIDER=mock
FCM_SERVICE_ACCOUNT_JSON=

WHATSAPP_PROVIDER=mock
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# =============================================================================
# STOCKAGE IMAGES CAMPAGNES
# Local  : MinIO via Docker (docker-compose up minio)
# Prod   : Amazon S3 (changer les 4 dernières variables)
#
# --- LOCAL (MinIO) ---
# CAMPAIGN_IMAGE_STORAGE_PROVIDER=s3
# CAMPAIGN_IMAGE_BUCKET=novasms-campaign-images
# CAMPAIGN_IMAGE_PUBLIC_BASE_URL=http://localhost:9000/novasms-campaign-images
# CAMPAIGN_IMAGE_S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000
# CAMPAIGN_IMAGE_S3_ENDPOINT=http://localhost:9000
# CAMPAIGN_IMAGE_S3_ACCESS_KEY_ID=minioadmin
# CAMPAIGN_IMAGE_S3_SECRET_ACCESS_KEY=minioadmin
# CAMPAIGN_IMAGE_S3_FORCE_PATH_STYLE=true
#
# --- PRODUCTION (Amazon S3) ---
# CAMPAIGN_IMAGE_STORAGE_PROVIDER=s3
# CAMPAIGN_IMAGE_BUCKET=novasms-campaign-images-prod
# CAMPAIGN_IMAGE_PUBLIC_BASE_URL=https://novasms-campaign-images-prod.s3.eu-west-3.amazonaws.com
# CAMPAIGN_IMAGE_S3_REGION=eu-west-3
# S3_ENDPOINT=                        # laisser vide pour AWS S3 natif
# CAMPAIGN_IMAGE_S3_ENDPOINT=         # laisser vide pour AWS S3 natif
# CAMPAIGN_IMAGE_S3_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# CAMPAIGN_IMAGE_S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CAMPAIGN_IMAGE_S3_FORCE_PATH_STYLE=false
# =============================================================================

# Valeurs actives (local MinIO par défaut) :
CAMPAIGN_IMAGE_STORAGE_PROVIDER=s3
CAMPAIGN_IMAGE_BUCKET=novasms-campaign-images
CAMPAIGN_IMAGE_PUBLIC_BASE_URL=http://localhost:9000/novasms-campaign-images
CAMPAIGN_IMAGE_S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
CAMPAIGN_IMAGE_S3_ENDPOINT=http://localhost:9000
CAMPAIGN_IMAGE_S3_ACCESS_KEY_ID=minioadmin
CAMPAIGN_IMAGE_S3_SECRET_ACCESS_KEY=minioadmin
CAMPAIGN_IMAGE_S3_FORCE_PATH_STYLE=true
