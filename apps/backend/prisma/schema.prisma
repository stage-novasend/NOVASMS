generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id              String    @id @default(uuid())
  companyName     String    @db.VarChar(255)
  adminEmail      String    @unique @db.VarChar(255)
  passwordHash    String    @db.VarChar(255)
  country         String    @db.Char(3)
  creditBalance   Decimal   @default(0) @db.Decimal(12,2)
  alertThreshold  Decimal?  @db.Decimal(12,2)
  createdAt       DateTime  @default(now()) @db.Timestamp
  gdprStatus      String    @default("active") @db.VarChar(50)
  emailVerified   Boolean   @default(false)
  confirmationToken String? @unique
  tokenExpiry     DateTime?
  loginAttempts   Int       @default(0)
  lockedUntil     DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorCode   String?   @db.VarChar(10)
  twoFactorCodeExpiry DateTime?
  twoFactorSecret String?   @db.VarChar(64)
  backupCodes     String[]  @default([])
  onboardingCompleted Boolean @default(false)
  users           User[]
  contacts        Contact[]
  segments        Segment[]
  campaigns       Campaign[]
  automations     Automation[]
  transactions    Transaction[]
  templates       Template[]
  auditLogs       AuditLog[]
  invitations     Invitation[]
  importReports   ImportReport[]
  jobs            Job[]

  @@map("accounts")
}

model User {
  id              String    @id @default(uuid())
  accountId       String
  account         Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  email           String    @unique @db.VarChar(255)
  passwordHash    String    @db.VarChar(255)
  role            String    @db.VarChar(20)
  twoFactorEnabled Boolean  @default(false)
  lastLogin       DateTime? @db.Timestamp

  auditLogs       AuditLog[]

  @@map("users")
}

model Contact {
  id          String   @id @default(uuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(20)
  firstName   String?  @db.VarChar(100)
  lastName    String?  @db.VarChar(100)
  location    String?  @db.VarChar(100)  // Added for filtering
  tags        Json?
  createdAt   DateTime @default(now()) @db.Timestamp
  optOut      Boolean  @default(false)

  consents    Consent[]
  sends       Send[]
  analytics   Analytic[]
  
  // Indexes for performance
  @@index([accountId, email])
  @@index([accountId, phone])
  @@index([accountId, createdAt])
  @@index([accountId, location])
  @@index([accountId, optOut])
  @@index([accountId, firstName])
  @@index([accountId, lastName])

  // For tag filtering, we need a GIN index which Prisma doesn't fully support yet
  // This would need to be added manually to the database

  @@map("contacts")
}

model Segment {
  id             String    @id @default(uuid())
  accountId      String
  account        Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name           String?   @db.VarChar(255)
  type           String?   @db.VarChar(20)
  criteria       Json?
  contactCount   Int       @default(0)
  lastCalculated DateTime? @db.Timestamp
  // Index for performance
  @@index([accountId])

  @@map("segments")
}

model Campaign {
  id                String    @id @default(uuid())
  accountId         String
  account           Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  channelType       String    @db.VarChar(20)
  subject           String?   @db.VarChar(255)
  content           String?   @db.Text
  status            String    @db.VarChar(20)
  scheduledAt       DateTime? @db.Timestamp
  estimatedCost     Decimal?  @db.Decimal(12,2)

  sends               Send[]
  analytics           Analytic[]
  engagementHeatmaps  EngagementHeatmap[]
  clickHeatmaps       ClickHeatmap[]

  @@map("campaigns")
}

model Send {
  id          String    @id @default(uuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status      String    @db.VarChar(20)
  sentAt      DateTime? @db.Timestamp
  openedAt    DateTime? @db.Timestamp
  clickedAt   DateTime? @db.Timestamp

  @@map("sends")
}

model Automation {
  id             String   @id @default(uuid())
  accountId      String
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name           String?  @db.VarChar(255)
  triggerEvent   String?  @db.VarChar(100)
  delaySeconds   Int?
  workflow       Json?
  status         String   @db.VarChar(20)

  @@map("automations")
}

model Transaction {
  id         String   @id @default(uuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount     Decimal  @db.Decimal(12,2)
  method     String?  @db.VarChar(20)
  reference  String?  @db.VarChar(255)
  status     String   @db.VarChar(20)
  createdAt  DateTime @default(now()) @db.Timestamp

  invoice    Invoice?

  @@map("transactions")
}

model Template {
  id           String   @id @default(uuid())
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name         String?  @db.VarChar(255)
  channelType  String?  @db.VarChar(20)
  htmlContent  String?  @db.Text
  isPreset     Boolean  @default(false)

  @@map("templates")
}

model AuditLog {
  id          String    @id @default(uuid())
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  action      String?   @db.VarChar(255)
  createdAt   DateTime  @default(now()) @db.Timestamp
  details     Json?

  @@map("audit_logs")
  @@index([accountId, createdAt]) // Added for performance in audit queries
}

model Invitation {
  id        String   @id @default(uuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  email     String   @db.VarChar(255)
  role      String   @db.VarChar(20)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @db.Timestamp
  status    String   @db.VarChar(20)

  @@map("invitations")
}

model ImportReport {
  id             String   @id @default(uuid())
  accountId      String
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  fileName       String?  @db.VarChar(255)
  totalRecords   Int?
  successCount   Int?
  duplicateCount Int?
  errorCount     Int?
  createdAt      DateTime @default(now()) @db.Timestamp

  @@map("import_reports")
}

model Job {
  id          String   @id @default(uuid())
  type        String?  @db.VarChar(50)
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  status      String   @db.VarChar(20)
  createdAt   DateTime @default(now()) @db.Timestamp
  finishedAt  DateTime? @db.Timestamp

  @@map("jobs")
}

model Analytic {
  id          String    @id @default(uuid())
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])
  action      String?   @db.VarChar(20)
  createdAt   DateTime? @db.Timestamp

  @@map("analytics")
}

model EngagementHeatmap {
  id          String @id @default(uuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  hour        Int
  openCount   Int    @default(0)
  clickCount  Int    @default(0)

  @@map("engagement_heatmap")
}

model ClickHeatmap {
  id         String @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  zone       String? @db.VarChar(255)
  clickCount Int    @default(0)

  @@map("click_heatmap")
}

model Consent {
  id           String   @id @default(uuid())
  contactId    String
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  consentedAt  DateTime @default(now()) @db.Timestamp
  source       String?  @db.VarChar(255)

  @@map("consents")
}

model Invoice {
  id            String   @id @default(uuid())
  transactionId String?  @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  s3Path        String?  @db.VarChar(255)
  createdAt     DateTime @default(now()) @db.Timestamp

  @@map("invoices")
}