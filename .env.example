# =============================================================================
# NovaSMS — Configuration multi-providers
# STAGING ET PRODUCTION = EXACTEMENT LE MÊME CODE. Seul .env diffère.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api
FRONTEND_URL=http://localhost:5173

# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://novasms:novasms_dev_password_2026@localhost:5432/novasms_db?schema=public

# ─── Redis / BullMQ ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=novasms:

# ─── Auth JWT ─────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_in_production_min_32_chars
JWT_REFRESH_SECRET=change_me_in_production_min_32_chars_different
JWT_ACCESS_EXPIRATION=8h
JWT_REFRESH_EXPIRATION=30d

# =============================================================================
# PROVIDERS EMAIL
# EMAIL_PROVIDER=resend | brevo | mock
# Staging  → EMAIL_PROVIDER=mock
# Prod     → EMAIL_PROVIDER=resend  (ou brevo)
# =============================================================================
EMAIL_PROVIDER=mock

# Resend (prod)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Brevo (prod fallback)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
BREVO_SENDER_EMAIL=no-reply@novasms.io
BREVO_SENDER_NAME=NovaSMS

# =============================================================================
# PROVIDERS SMS
# SMS_PROVIDER=simulation | novasend | twilio | africastalking
# Staging  → SMS_PROVIDER=simulation  (logs console, aucun envoi réel)
# Prod     → SMS_PROVIDER=novasend    (ou twilio / africastalking)
# =============================================================================
SMS_PROVIDER=simulation

# NovaSend SMS (prod West Africa)
NOVASEND_SMS_API_KEY=ns_sms_xxxxxxxxxxxxxxxxxxxx
NOVASEND_SMS_SENDER_ID=NovaSMS
NOVASEND_SMS_BASE_URL=https://api.novasend.io/v1

# Twilio (prod)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Africa's Talking (prod fallback)
AFRICASTALKING_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=NovaSMS
# AFRICASTALKING_BASE_URL=  # laisser vide → auto-détection sandbox/prod

# =============================================================================
# PROVIDERS MOBILE MONEY
# MOBILE_MONEY_PROVIDER=simulation | novasend
# Staging  → MOBILE_MONEY_PROVIDER=simulation  (succès immédiat, logs console)
# Prod     → MOBILE_MONEY_PROVIDER=novasend
# =============================================================================
MOBILE_MONEY_PROVIDER=simulation

# NovaSend Mobile Money (prod)
NOVASEND_MM_API_KEY=ns_mm_xxxxxxxxxxxxxxxxxxxx
NOVASEND_MM_BASE_URL=https://api.novasend.io/v1

# URLs opérateurs (optionnel — surcharge les URLs par défaut)
# MM_ORANGE_PROD_URL=https://api.orange.com/orange-money-webpay/v1
# MM_ORANGE_STAGING_URL=https://apiw.orange.com/orange-money-webpay/dev/v1
# MM_MTN_PROD_URL=https://proxy.momoapi.mtn.com/collection/v1_0
# MM_MTN_STAGING_URL=https://sandbox.momodeveloper.mtn.com/collection/v1_0

# =============================================================================
# PROVIDERS VISA / CARTE
# VISA_PROVIDER=simulation | stripe
# Staging  → VISA_PROVIDER=simulation  (succès immédiat, aucun appel Stripe)
# Prod     → VISA_PROVIDER=stripe      (sk_live_xxx)
# Test     → VISA_PROVIDER=stripe      (sk_test_xxx → flux auto pm_card_visa)
# =============================================================================
VISA_PROVIDER=simulation

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# PROVIDERS PUSH / WHATSAPP
# =============================================================================
PUSH_PROVIDER=mock
FCM_SERVICE_ACCOUNT_JSON=

WHATSAPP_PROVIDER=mock
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# =============================================================================
# FRONTEND (Vite)
# =============================================================================
VITE_API_BASE_URL=http://localhost:3000/api
VITE_APP_NAME=NovaSMS
VITE_APP_ENV=development
# VITE_IS_STAGING=true   → affiche les badges "Simulation" sur les providers
VITE_IS_STAGING=true
